{
  "manifest_version": 3,
  "name": "LinkedIn Resume Tailor MVP",
  "version": "0.2.0",
  "description": "Score and tailor your resume for active LinkedIn job pages.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "sidePanel"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Resume Tailor"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
